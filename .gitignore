# ignored, only the top-level figs/ output dir.
/figs/
/results/
/manuscript/

# === Exceptions: spatial model outputs for report figures ===
!figs/pub_fig_spatial_*.png
!results/pub_spatial_table*.csv

# === Exceptions: effort confounding diagnostics ===
!figs/pub_fig_effort_*.png
!results/pub_effort_confounding_summary.csv
!results/pub_effort_interpretation.txt

# === Exceptions: stepRep diagnostic report figures ===
!reports/figs/stepRep_*.png

# === Temporary / cache ===
*.RData
*.rds
*_cache/
*_files/
.Rcache/
Rplots.pdf

